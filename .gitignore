# Python bytecode
__pycache__/
*.py[cod]
*$py.class

# Packaging / build output (setuptools editable install; PyInstaller one-file build at M9)
build/
dist/
*.egg-info/
.eggs/

# Virtual environment / local env
.venv/
venv/
.env

# Tooling caches
.pytest_cache/
.ruff_cache/
.mypy_cache/

# Coverage (if pytest-cov is added)
.coverage
coverage.xml
htmlcov/

# Editors
.vscode/
.idea/

# OS
.DS_Store
Thumbs.db

# EDS runtime state — NEVER commit (holds the enrollment token / server_id / session creds)
data/
config.toml
*.toml.bak
*.creds
